{
  "name": "cashlens-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-schema.mjs",
    "start": "node dist/index.js",
    "seed": "tsx src/db/seed.ts",
    "metrics": "tsx src/engine/metrics.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "openai": "^6.46.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
